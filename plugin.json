{
  "version": 1,
  "skill": "./SKILL.md",
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "./scripts/pre-tool-guard.sh",
        "powershell": "./scripts/pre-tool-guard.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 15
